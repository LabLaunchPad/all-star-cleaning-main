---
// Low-opacity domain-specific SVG line-art layered behind section content.
// Enterprise-grade restraint: thin strokes, low opacity, never competes with foreground text.
interface Props {
  variant: 'droplets' | 'spray-arc' | 'window-grid' | 'gutter-line' | 'snowflake';
  tint?: string; // CSS color value, defaults to currentColor via midnight-indigo
  opacity?: number; // 0-1, default 0.06
  position?: 'left' | 'right' | 'full';
}
const { variant, tint = 'var(--color-midnight-indigo)', opacity = 0.06, position = 'right' } = Astro.props;

const positionClass =
  position === 'left' ? 'left-0 -translate-x-1/4' :
  position === 'right' ? 'right-0 translate-x-1/4' :
  'left-1/2 -translate-x-1/2';
---

<div
  class:list={['pointer-events-none absolute top-0 h-full w-full max-w-3xl overflow-hidden', positionClass]}
  style={`opacity: ${opacity}; color: ${tint};`}
  aria-hidden="true"
>
  {variant === 'droplets' && (
    <svg viewBox="0 0 400 600" class="h-full w-full" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M100 80c0 22-18 40-40 40S20 102 20 80c0-22 40-70 40-70s40 48 40 70z" />
      <path d="M340 200c0 16-13 29-29 29s-29-13-29-29c0-16 29-52 29-52s29 36 29 52z" />
      <path d="M60 340c0 18-15 33-33 33s-33-15-33-33c0-18 33-58 33-58s33 40 33 58z" />
      <path d="M300 460c0 14-11 25-25 25s-25-11-25-25c0-14 25-46 25-46s25 32 25 46z" />
      <path d="M140 540c0 11-9 20-20 20s-20-9-20-20c0-11 20-36 20-36s20 25 20 36z" />
    </svg>
  )}

  {variant === 'spray-arc' && (
    <svg viewBox="0 0 400 600" class="h-full w-full" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M20 500 Q 200 100 380 500" />
      <path d="M60 520 Q 200 160 340 520" />
      <path d="M100 540 Q 200 220 300 540" />
      <circle cx="200" cy="100" r="3" fill="currentColor" stroke="none" />
      <circle cx="230" cy="130" r="2" fill="currentColor" stroke="none" />
      <circle cx="170" cy="140" r="2" fill="currentColor" stroke="none" />
      <circle cx="255" cy="175" r="2.5" fill="currentColor" stroke="none" />
    </svg>
  )}

  {variant === 'window-grid' && (
    <svg viewBox="0 0 400 600" class="h-full w-full" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="60" y="60" width="280" height="480" rx="4" />
      <line x1="200" y1="60" x2="200" y2="540" />
      <line x1="60" y1="300" x2="340" y2="300" />
    </svg>
  )}

  {variant === 'gutter-line' && (
    <svg viewBox="0 0 400 600" class="h-full w-full" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M20 80 H 340 a 20 20 0 0 1 20 20 V 460" />
      <path d="M340 460 V 560" stroke-dasharray="4 6" />
      <path d="M20 80 V 60" />
      <path d="M340 100 V 60" />
    </svg>
  )}

  {variant === 'snowflake' && (
    <svg viewBox="0 0 400 600" class="h-full w-full" fill="none" stroke="currentColor" stroke-width="1.5">
      <g transform="translate(200,300)">
        <line x1="0" y1="-160" x2="0" y2="160" />
        <line x1="-138" y1="-80" x2="138" y2="80" />
        <line x1="-138" y1="80" x2="138" y2="-80" />
        <line x1="0" y1="-160" x2="-30" y2="-120" />
        <line x1="0" y1="-160" x2="30" y2="-120" />
        <line x1="0" y1="160" x2="-30" y2="120" />
        <line x1="0" y1="160" x2="30" y2="120" />
      </g>
    </svg>
  )}
</div>
