---
// Unified pill/chip primitive — replaces the ad-hoc badge markup that had drifted
// slightly different padding/radius/icon-gap in three places: ServiceCard's accent
// badge, the homepage hero's trust pills, and services/index.astro's trust bar.
// Mirrors ServiceCard's proven --accent/--accent-surface/--accent-dark inline-style
// convention (see src/data/services.ts) rather than a runtime color-mix() — that
// convention exists specifically because dynamic CSS color tricks were unreliable
// in this project's Tailwind v4 build pipeline (see DESIGN.md's "Known quirk").
//
// The icon is a slot, not a `d`-string prop — most of this codebase's icons are
// two-path compounds (outline + accent mark), and concatenating multiple <path>
// elements into one `d` string risks silently breaking relative-coordinate
// commands (m/l) that were only ever correct relative to their own subpath.
//
// Also absorbs the former ServiceBadge.astro (neighbour-location link pills) —
// those aren't small-caps trust labels, they're proper nouns (place names), so
// `caps={false}` switches to normal-case/semibold type instead of the
// bold/uppercase/tracking-widest default. Same shape, two real typographic
// registers, not one component pretending to be two.
//
// `caps={false}` also absorbs the "Insured & Bonded" / "100% Guarantee" info
// pills hand-rolled identically in about.astro, services/index.astro (×2),
// services/[serviceSlug].astro, and area/[locationSlug]/[serviceSlug].astro —
// all five used the same text-sm/font-semibold size, so that's the size this
// mode standardizes on (not the smaller text-xs the two link-pill instances
// happened to use previously).
interface Props {
  label: string;
  href?: string;
  tone?: 'neutral' | 'accent' | 'dark' | 'brand';
  caps?: boolean;
  accentColor?: string;
  accentSurface?: string;
  accentDark?: string;
  class?: string;
}
const { label, href, tone = 'neutral', caps = true, accentColor, accentSurface, accentDark, class: className = '' } = Astro.props;
const accentStyle = tone === 'accent' && accentColor && accentSurface && accentDark
  ? `--accent: ${accentColor}; --accent-surface: ${accentSurface}; --accent-dark: ${accentDark};`
  : undefined;
const classes = [
  'inline-flex items-center rounded-full',
  'px-[var(--space-badge-x)] py-[var(--space-badge-y)] gap-[var(--space-icon-gap)]',
  caps ? 'text-[11px] font-bold uppercase tracking-widest' : 'text-sm font-semibold',
  tone === 'neutral' && 'border border-border bg-card text-muted-foreground',
  tone === 'dark' && 'border border-text-on-dark/20 bg-text-on-dark/10 text-text-on-dark',
  tone === 'brand' && 'border border-midnight-indigo/20 bg-midnight-indigo/10 text-midnight-indigo',
  tone === 'accent' && 'border border-[var(--accent)]/40 bg-[var(--accent-surface)] text-[var(--accent-dark)]',
  href && 'touch-target transition-colors hover:opacity-80 focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2',
  className,
];
---
{href ? (
  <a href={href} style={accentStyle} class:list={classes}>
    <slot name="icon" />
    {label}
  </a>
) : (
  <span style={accentStyle} class:list={classes}>
    <slot name="icon" />
    {label}
  </span>
)}
