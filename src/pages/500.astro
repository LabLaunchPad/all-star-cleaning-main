---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Detect locale from URL path or default to 'en'
const pathname = Astro.url.pathname;
const localeFromUrl = pathname.startsWith('/fr') ? 'fr' : 'en';
const isFr = localeFromUrl === 'fr';
---
<BaseLayout
  title={isFr ? 'Erreur Serveur | All Star Cleaning Ottawa' : 'Server Error | All Star Cleaning Ottawa'}
  description={isFr ? "Une erreur serveur est survenue. Veuillez réessayer plus tard." : "A server error occurred. Please try again later."}
  locale={localeFromUrl}
  noindex={true}
>
  <section class="flex min-h-[60vh] flex-col items-center justify-center px-4 py-24 text-center">
    <!-- Warning / alert SVG illustration -->
    <div class="slide-up mb-6 text-midnight-indigo" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <!-- Alert triangle -->
        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
        <path d="M12 9v4"/>
        <path d="M12 17h.01"/>
      </svg>
    </div>
    <h1 class="slide-up font-heading text-6xl font-bold text-midnight-indigo">500</h1>
    <p class="slide-up mt-4 text-lg text-muted-foreground">
      {isFr
        ? 'Oups ! Quelque chose a mal tourné.'
        : 'Oops! Something went wrong.'}
    </p>
    <p class="slide-up mt-2 text-muted-foreground">
      {isFr
        ? "Une erreur serveur est survenue. Notre équipe a été notifiée et travaille pour résoudre le problème."
        : "A server error occurred. Our team has been notified and is working to fix the issue."}
    </p>
    <a
      href={`/${localeFromUrl}`}
      class="slide-up mt-8 inline-flex items-center gap-2 rounded-none uppercase tracking-wider bg-midnight-indigo px-8 py-3.5 text-lg font-semibold text-text-on-dark shadow-lg transition-colors duration-200 hover:bg-midnight-indigo-dark hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-midnight-indigo touch-target"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      {isFr ? "Retour à l'accueil" : 'Go Home'}
    </a>
    <div class="slide-up mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href={`/${localeFromUrl}/services`} class="rounded-full border border-border px-5 py-3 text-sm font-medium text-muted-foreground transition-colors hover:border-midnight-indigo hover:text-midnight-indigo touch-target">{isFr ? 'Nos Services' : 'Our Services'}</a>
      <a href={`/${localeFromUrl}/contact`} class="rounded-full border border-border px-5 py-3 text-sm font-medium text-muted-foreground transition-colors hover:border-midnight-indigo hover:text-midnight-indigo touch-target">{isFr ? 'Contactez-nous' : 'Contact Us'}</a>
      <a href={`/${localeFromUrl}/reviews`} class="rounded-full border border-border px-5 py-3 text-sm font-medium text-muted-foreground transition-colors hover:border-midnight-indigo hover:text-midnight-indigo touch-target">{isFr ? 'Témoignages' : 'Reviews'}</a>
    </div>
  </section>
</BaseLayout>
