---
// Dynamic locale homepage — Astro v6
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import ServiceCardMarquee from '@/components/ServiceCardMarquee.astro';
import SectionMotif from '@/components/SectionMotif.astro';
import Badge from '@/components/Badge.astro';
import StatTile from '@/components/StatTile.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import { services } from '@/data/services';
import { useTranslations } from '@/i18n/translations';
import { getHowToSchema, getBreadcrumbSchema, getFAQSchema } from '@/seo';
import homepageData from '@/content/homepage.json';
import siteSettings from '@/content/settings.json';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}

const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const howtoSchema = getHowToSchema(locale);
const homeBreadcrumbSchema = getBreadcrumbSchema([
  { label: t.nav.home, frLabel: t.nav.home, href: `/${locale}` },
], locale);
const usps = [
  { icon: 'shield', title: t.usps.expertise.title, description: t.usps.expertise.description },
  { icon: 'sparkles', title: t.usps.equipment.title, description: t.usps.equipment.description },
  { icon: 'check-circle', title: t.usps.guarantee.title, description: t.usps.guarantee.description },
];


// CMS-managed content (editable via Keystatic at /keystatic)
const cms = homepageData;
const faqSchema = cms.faqs && cms.faqs.length > 0 ? getFAQSchema(cms.faqs, locale) : null;
---

<BaseLayout
  title={isFr ? 'All Star Cleaning Ottawa | Nettoyage de Vitres, Gouttières et Lavage sous Pression' : 'All Star Cleaning Ottawa | Window, Gutter & Pressure Washing'}
  description={isFr ? 'Service de nettoyage de confiance à Ottawa. Nettoyage de vitres, gouttières, lavage sous pression, revêtement et déneigement. Devis gratuits.' : "Ottawa's trusted cleaning service. Window cleaning, gutter cleaning, pressure washing, siding cleaning & snow removal. Free quotes: residential & commercial."}
  locale={locale}
  ogImage="https://allstarcleaning.ca/og-default.jpg"
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/` }]}
  schema={[howtoSchema, homeBreadcrumbSchema, ...(faqSchema ? [faqSchema] : [])]}
>
  <!-- ============================================================ -->
  <!-- HERO SECTION — Full-screen bg image + centered overlay (SHINE layout) -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Accueil' : 'Homepage hero'} class="relative flex min-h-[85vh] items-center justify-center overflow-hidden md:min-h-screen pt-4 sm:pt-10">
    <!-- Background image with dark blue overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src={cms.heroImage}
        alt="All Star Cleaning — sparkling clean Ottawa home"
        role="presentation"
        width="1344"
        height="768"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-midnight-indigo-dark/95 via-midnight-indigo-dark/80 to-midnight-indigo-dark/95"></div>
    </div>

    <!-- Centered hero content -->
    <div class="relative z-10 mx-auto max-w-5xl px-4 py-10 text-center sm:px-6 sm:py-16">
      <img src="/images/logo.png" alt="All Star Cleaning" width="180" height="60" class="slide-up mx-auto mb-8 h-20 w-auto sm:h-24 brightness-0 invert object-contain" />
      <h1 class="slide-up font-heading text-3xl font-extrabold uppercase tracking-tight text-text-on-dark sm:text-5xl md:text-6xl lg:text-8xl">
        {isFr ? cms.heroHeadlineFr : cms.heroHeadlineEn}
      </h1>
      <p class="fade-in delay-2 mx-auto mt-6 max-w-2xl text-lg font-medium text-text-on-dark-muted sm:text-xl md:text-2xl">
        {isFr ? cms.heroSubtitleFr : cms.heroSubtitleEn}
      </p>
      
      <div class="fade-in delay-4 mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={`/${locale}/contact`} class="touch-target group inline-flex w-full items-center justify-center gap-3 rounded-full bg-white px-10 py-4 text-lg font-bold uppercase tracking-wider text-midnight-indigo shadow-2xl transition-colors hover:bg-white/90 hover:scale-105 active:scale-95 sm:w-auto">
          {isFr ? 'Obtenez un Devis' : 'Get a Quote'}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>

      <!-- Trust badges (Stacked Layout for visual balance) -->
      <div class="fade-in delay-5 mt-12 flex flex-col items-center gap-3">
        <!-- Top Row: Uniform sizing -->
        <div class="flex flex-wrap items-center justify-center gap-3">
          <!-- Free Estimates -->
          <Badge
            label={isFr ? 'Devis Gratuits' : 'Free Estimates'}
            tone="accent"
            accentColor="oklch(78% 0.18 70)"
            accentSurface="oklch(78% 0.18 70 / 0.1)"
            accentDark="var(--color-text-on-dark)"
            class="min-w-[150px] justify-center !text-[10px] sm:!text-xs"
          >
            <svg slot="icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          </Badge>

          <!-- Google Rating -->
          <a 
            href={siteSettings.googleUrl} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="touch-target flex min-w-[150px] items-center justify-center gap-2 rounded-full bg-white/10 px-4 py-2.5 border border-white/20 transition-transform hover:bg-white/20 hover:scale-105 active:scale-95"
            aria-label={isFr ? 'Voir nos avis Google (ouvre une nouvelle fenêtre)' : 'See our Google Reviews (opens in new window)'}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c3.11 0 5.72-1.03 7.63-2.77l-3.57-2.77c-1.01.68-2.31 1.09-4.06 1.09-3.13 0-5.78-2.11-6.73-4.96H2.62v2.87C4.52 20.38 8.04 23 12 23z" fill="#34A853"/><path d="M5.27 13.59c-.24-.71-.38-1.47-.38-2.27 0-.79.14-1.55.38-2.26V6.19H2.62C1.81 7.82 1.35 9.66 1.35 11.62c0 1.96.46 3.8 1.27 5.43l2.65-2.07z" fill="#FBBC05"/><path d="M12 4.39c1.7 0 3.22.58 4.42 1.73l3.31-3.31C17.71 1.05 15.09 0 12 0 8.04 0 4.52 2.62 2.62 6.19l3.3 2.57C6.88 6.5 9.53 4.39 12 4.39z" fill="#EA4335"/></svg>
            <div class="flex text-yellow-400">
              {[...Array(5)].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 sm:h-3.5 sm:w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="text-xs font-bold text-text-on-dark">{cms.googleRating}</span>
          </a>
        </div>

        <!-- Bottom Row: Primary Trust -->
        <Badge
          label={isFr ? 'Assuré & Cautionné' : 'Insured & Bonded'}
          tone="accent"
          accentColor="oklch(65% 0.20 150)"
          accentSurface="oklch(65% 0.20 150 / 0.1)"
          accentDark="var(--color-text-on-dark)"
          class="min-w-[200px] justify-center px-6 !text-[10px] sm:!text-xs"
        >
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        </Badge>
      </div>
    </div>

    <!-- Bottom scroll indicator -->
    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 animate-bounce opacity-30">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-text-on-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 13 5 5 5-5"/><path d="m7 6 5 5 5-5"/></svg>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- PROOF STRIP — bold-number stats, real local-trust numbers only.
       Uses homepage.json fields that already existed (statsRatingEn/Fr,
       statsSatisfactionEn/Fr, statsDaysEn/Fr) but were never rendered
       anywhere — not new content, just finally surfaced. -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Nos chiffres' : 'Our numbers'} class="border-b border-border bg-card py-8 md:py-10">
    <div class="mx-auto grid max-w-3xl grid-cols-3 gap-4 px-4 md:max-w-4xl md:gap-8 md:px-6">
      <StatTile align="center" value={String(cms.googleReviewCount)} suffix="+" label={isFr ? cms.statsRatingFr : cms.statsRatingEn} />
      <StatTile align="center" value="100" suffix="%" label={isFr ? cms.statsSatisfactionFr : cms.statsSatisfactionEn} />
      <StatTile align="center" value="7" label={isFr ? cms.statsDaysFr : cms.statsDaysEn} />
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- USP SECTION — Image + feature cards split layout -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Pourquoi nous choisir' : 'Why choose us'} class="relative z-0 overflow-hidden bg-card pt-16 pb-8 md:pt-20 md:pb-10 lg:pt-24 lg:pb-12" style="content-visibility: auto; contain-intrinsic-size: 0 600px">
    <SectionMotif variant="droplets" tint="var(--color-vivid-blue)" position="right" opacity={0.05} />
    <div class="relative mx-auto max-w-7xl px-4 md:px-6">
      <!-- Decorative blue accent line -->
      <div class="mb-10 h-px w-full bg-midnight-indigo/20 md:mb-12"></div>

      <div class="grid gap-8 lg:grid-cols-2 lg:gap-12 items-center">
        <!-- Left column: Image of team at work -->
        <div class="fade-in relative z-0 order-2 lg:order-1">
          <div class="overflow-hidden rounded-2xl shadow-lg">
            <img
              src={cms.teamImage}
              alt={isFr ? "L'équipe All Star Cleaning au travail à Ottawa" : 'All Star Cleaning crew at work in Ottawa'}
              width="1344"
              height="768"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Right column: Text + feature cards -->
        <div class="order-1 lg:order-2">
          <h2 class="heading-section slide-up font-heading font-extrabold text-midnight-indigo">
            {isFr ? 'Pourquoi Choisir All Star?' : 'Why Choose All Star?'}
          </h2>
          <p class="fade-in delay-2 mt-4 measure text-lg text-muted-foreground">
            {isFr
              ? "Expertise locale, équipement de qualité professionnelle et une garantie de satisfaction sans tracas: c'est ce qui nous distingue à Ottawa."
              : 'Local expertise, professional-grade equipment, and a hassle-free satisfaction guarantee: that\'s what sets us apart in Ottawa.'}
          </p>

          <!-- Feature cards stacked -->
          <div class="mt-8 flex flex-col gap-4">
            {usps.map((usp) => (
              <div
                style="box-shadow: var(--shadow-stacked);"
                class:list={[
                  'fade-in rounded-xl border p-5 flex items-start gap-4 transition-transform duration-300 hover:-translate-y-0.5',
                  usp.icon === 'shield' ? 'bg-emerald-subtle border-[var(--color-green-light)]/20' :
                  usp.icon === 'sparkles' ? 'bg-sky-subtle border-[var(--color-sky-light)]/20' :
                  'bg-amber-subtle border-[var(--color-amber-light)]/20'
                ]}
              >
                <div class:list={[
                  'flex h-10 w-10 shrink-0 items-center justify-center rounded-full',
                  usp.icon === 'shield' ? 'bg-[var(--color-green)]/10 text-[var(--color-green-dark)]' :
                  usp.icon === 'sparkles' ? 'bg-[var(--color-sky)]/10 text-[var(--color-sky-dark)]' :
                  'bg-[var(--color-amber)]/10 text-[var(--color-amber-dark)]'
                ]}>
                  {usp.icon === 'shield' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  )}
                  {usp.icon === 'sparkles' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                  )}
                  {usp.icon === 'check-circle' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  )}
                </div>
                <div>
                  <h3 class:list={[
                    'font-heading text-base font-semibold',
                    usp.icon === 'shield' ? 'text-emerald-bold' :
                    usp.icon === 'sparkles' ? 'text-sky-bold' :
                    'text-amber-bold'
                  ]}>{usp.title}</h3>
                  <p class="mt-1 measure text-base leading-relaxed text-muted-foreground">{usp.description}</p>
                </div>
              </div>
            ))}
          </div>

          <a href={`/${locale}/contact`} class="group fade-in delay-3 mt-8 inline-flex items-center gap-2 rounded-lg px-4 py-3 text-sm font-semibold text-midnight-indigo transition-colors hover:bg-midnight-indigo/5 hover:text-midnight-indigo-dark focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2 touch-target">
            {isFr ? 'Obtenez votre devis gratuit' : 'Get your free quote'}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SERVICES SECTION — Varied grid with featured first card -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Nos services' : 'Our services'} class="divider-angle-up relative z-0 overflow-hidden bg-background pt-8 pb-16 md:pt-10 md:pb-20 lg:pt-12 lg:pb-24" style="content-visibility: auto; contain-intrinsic-size: 0 800px">
    <SectionMotif variant="spray-arc" tint="var(--color-vivid-green)" position="left" opacity={0.05} />
    <div class="relative mx-auto max-w-7xl px-4 md:px-6">
      <div class="text-center">
        <h2 class="heading-subsection slide-up font-heading font-extrabold text-midnight-indigo">{isFr ? 'Nos Services' : 'Our Services'}</h2>
        <p class="fade-in delay-2 mx-auto mt-4 max-w-2xl measure text-muted-foreground">{isFr ? "Des fenêtres étincelantes aux allées déneigées, nous couvrons tout Ottawa." : "From sparkling windows to snow-free driveways, we've got Ottawa covered."}</p>
      </div>
      <div class="mt-12">
        <ServiceCardMarquee services={services} locale={locale} learnMoreText={t.ui.learnMore} cardVariant="bleed" />
        <div class="hidden md:grid md:grid-cols-2 gap-6 lg:grid-cols-3">
          {services.map((service, i) => (
            <ServiceCard
              service={service}
              locale={locale}
              featured={i === 0}
              variant={i === 0 ? 'bleed' : 'inset'}
              learnMoreText={t.ui.learnMore}
              delayClass={`delay-${Math.min(i + 1, 5)}`}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TRUST / TESTIMONIAL SECTION — Real customer quote -->
  <!-- ============================================================ -->
  <section class="relative z-0 overflow-hidden bg-midnight-indigo py-16 text-text-on-dark md:py-20" aria-label={isFr ? 'Témoignage client' : 'Customer testimonial'} style="content-visibility: auto; contain-intrinsic-size: 0 400px">
    <SectionMotif variant="window-grid" tint="var(--color-text-on-dark)" position="full" opacity={0.04} />
    <div class="relative mx-auto max-w-3xl px-4 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-8 w-8 text-text-on-dark/30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
      <blockquote class="mt-6 text-xl font-medium leading-relaxed text-text-on-dark sm:text-2xl">
        {isFr
          ? "Service exceptionnel ! Ils ont nettoyé nos gouttières et fenêtres en une seule visite. L'équipe était ponctuelle, professionnelle et a tout laissé impeccable."
          : "Outstanding service! They cleaned our gutters and windows in a single visit. The crew was on time, professional, and left everything spotless."}
      </blockquote>
      <p class="mt-6 text-sm text-text-on-dark-muted">
        — Sarah Mitchell, {isFr ? 'Nettoyage de gouttières' : 'Gutter Cleaning'}
      </p>
      <div class="mt-4 flex items-center justify-center gap-1 text-amber-surface" role="img" aria-label="5 out of 5 stars">
        {[...Array(5)].map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        ))}
      </div>
      <p class="mt-2 text-[11px] text-text-on-dark-muted sm:text-xs">{isFr ? `${cms.googleReviewCount} avis Google vérifiés` : `${cms.googleReviewCount} verified Google reviews`}</p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- HOW IT WORKS SECTION — 3-step process with before/after image -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Comment ça marche' : 'How it works'} class="relative z-0 overflow-hidden py-16 md:py-20 lg:py-24" style="content-visibility: auto; contain-intrinsic-size: 0 700px">
    <SectionMotif variant="gutter-line" tint="var(--color-vivid-amber)" position="right" opacity={0.05} />
    <div class="relative mx-auto max-w-7xl px-4 md:px-6">
      <div class="text-center">
        <h2 class="heading-subsection slide-up font-heading font-extrabold text-midnight-indigo">{isFr ? 'Comment Ça Marche' : 'How It Works'}</h2>
        <p class="fade-in delay-2 mx-auto mt-4 max-w-2xl measure text-muted-foreground">{isFr ? "Obtenez un extérieur impeccable en trois étapes simples. C'est aussi facile que ça." : 'Get a spotless exterior in three simple steps. It\'s that easy.'}</p>
      </div>

      <!-- 3-step process -->
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        <!-- Step 1 -->
        <div class="fade-in text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-[var(--color-sky)]/10 text-[var(--color-sky-dark)] border-2 border-[var(--color-sky-light)]/20">
            <span class="font-heading text-3xl font-bold">1</span>
          </div>
          <h3 class="mt-5 font-heading text-lg font-extrabold text-sky-bold">{isFr ? 'Obtenez un Devis Gratuit' : 'Get a Free Quote'}</h3>
          <p class="mt-2 measure text-base text-muted-foreground">{isFr ? "Appelez-nous ou remplissez notre formulaire en ligne. Nous vous répondons sous 24 heures avec un devis gratuit et sans engagement." : 'Call us or fill out our online form. We respond within 24 hours with a free, no-obligation quote.'}</p>
        </div>
        <!-- Step 2 -->
        <div class="fade-in delay-1 text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-midnight-indigo/10 text-midnight-indigo border-2 border-midnight-indigo/20">
            <span class="font-heading text-3xl font-bold">2</span>
          </div>
          <h3 class="mt-5 font-heading text-lg font-extrabold text-midnight-indigo">{isFr ? 'Nous Faisons le Travail' : 'We Do the Work'}</h3>
          <p class="mt-2 measure text-base text-muted-foreground">{isFr ? "Notre équipe professionnelle arrive à l'heure, utilise un équipement de qualité et traite votre maison avec soin. Aucun dégât, aucun désordre." : 'Our professional crew arrives on time, uses premium equipment, and treats your home with care. No damage, no mess.'}</p>
        </div>
        <!-- Step 3 -->
        <div class="fade-in delay-2 text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-[var(--color-green)]/10 text-[var(--color-green-dark)] border-2 border-[var(--color-green-light)]/20">
            <span class="font-heading text-3xl font-bold">3</span>
          </div>
          <h3 class="mt-5 font-heading text-lg font-extrabold text-emerald-bold">{isFr ? 'Appréciez le Résultat' : 'Enjoy the Result'}</h3>
          <p class="mt-2 measure text-base text-muted-foreground">{isFr ? "Vitres étincelantes, gouttières propres, allées comme neuves. Et si vous n'êtes pas satisfait à 100%, nous revenons sans frais." : 'Sparkling windows, clean gutters, driveways like new. And if you\'re not 100% satisfied, we come back at no charge.'}</p>
        </div>
      </div>

      <!-- Before/After image -->
      <div class="fade-in delay-3 mt-14 overflow-hidden rounded-2xl shadow-lg">
        <img
          src={cms.beforeAfterImage}
          alt={isFr ? 'Résultats avant et après le nettoyage extérieur' : 'Before and after exterior cleaning results'}
          width="1344"
          height="768"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FAQ SECTION — addresses objections right before the closing CTA.
       Uses homepage.json's faqs field (new — mirrors the services
       collection's identical faqs shape) and the existing FAQAccordion
       component already proven on service-detail/location pages. -->
  <!-- ============================================================ -->
  {cms.faqs && cms.faqs.length > 0 && (
    <section aria-label={isFr ? 'Questions fréquentes' : 'Frequently asked questions'} class="bg-card py-16 md:py-20">
      <div class="mx-auto max-w-3xl px-4 md:px-6">
        <FAQAccordion
          faqs={cms.faqs}
          locale={locale}
          title={isFr ? 'Questions Fréquentes' : 'Frequently Asked Questions'}
        />
      </div>
    </section>
  )}

  <!-- ============================================================ -->
  <!-- CLOSING CTA — cms.ctaHeadline/ctaSubtitle/ctaImage existed in the
       CMS schema but were never rendered anywhere on the page; the
       homepage previously just ended after "How It Works". -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Demandez un devis' : 'Get a quote'} class="relative overflow-hidden py-20 md:py-24">
    <div class="absolute inset-0 z-0">
      <img
        src={cms.ctaImage}
        alt=""
        role="presentation"
        width="1344" height="768"
        class="h-full w-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-midnight-indigo-dark/90"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 text-center md:px-6">
      <h2 class="font-heading text-3xl font-extrabold text-text-on-dark md:text-4xl">
        {isFr ? cms.ctaHeadlineFr : cms.ctaHeadlineEn}
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-text-on-dark-muted">
        {isFr ? cms.ctaSubtitleFr : cms.ctaSubtitleEn}
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={`/${locale}/contact`} class="touch-target inline-flex w-full items-center justify-center gap-2 rounded-full bg-text-on-dark px-8 py-3.5 text-base font-bold uppercase tracking-wider text-midnight-indigo shadow-xl transition-colors duration-200 hover:bg-text-on-dark/90 sm:w-auto">
          {t.cta.freeQuote}
        </a>
        <a href={`tel:${cms.phoneLink}`} class="touch-target inline-flex w-full items-center justify-center gap-2 rounded-full border-2 border-text-on-dark/30 px-8 py-3.5 text-base font-bold uppercase tracking-wider text-text-on-dark transition-colors duration-200 hover:border-text-on-dark/60 hover:bg-text-on-dark/10 sm:w-auto">
          {cms.phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
