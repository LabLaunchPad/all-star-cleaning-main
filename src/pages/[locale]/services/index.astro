---
import PageLayout from '@/layouts/PageLayout.astro';
import GoogleReviewBadge from '@/components/GoogleReviewBadge.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import ServiceCardMarquee from '@/components/ServiceCardMarquee.astro';
import Badge from '@/components/Badge.astro';
import { useTranslations } from '@/i18n/translations';
import { services } from '@/data/services';
import { getBreadcrumbSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';
import homepageData from '@/content/homepage.json';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}

const { locale } = Astro.params as { locale: 'en' | 'fr' };
const isFr = locale === 'fr';
const t = useTranslations(locale);
const altLocale = isFr ? 'en' : 'fr';
const breadcrumbs: BreadcrumbItem[] = [
  { label: t.nav.home, frLabel: t.nav.home, href: `/${locale}` },
  { label: t.nav.services, frLabel: t.nav.services, href: `/${locale}/services` },
];

const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: services.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: isFr ? s.frName : s.name,
    url: `https://allstarcleaning.ca/${locale}/services/${s.slug}`,
  })),
};


const cms = homepageData;
---

<PageLayout
  title={isFr ? 'Nos Services de Nettoyage | All Star Cleaning Ottawa' : 'Professional Exterior Cleaning Services in Ottawa | All Star Cleaning'}
  description={isFr ? 'Services de nettoyage extérieur professionnels à Ottawa. Nettoyage de vitres, gouttières, lavage sous pression, revêtement et déneigement.' : 'Professional exterior cleaning services in Ottawa. Window cleaning, gutter cleaning, pressure washing, siding cleaning, and snow removal.'}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={t.servicesPage.heroTitle}
  heroSubtitle={t.servicesPage.heroSubtitle}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/services/` }]}
  schema={[breadcrumbSchema, itemListSchema]}
>
  <section class="py-8 sm:py-12">
    <!-- Trust Badge Bar -->
    <div class="mx-auto mb-8 max-w-7xl flex flex-wrap items-center justify-center gap-4 px-4 md:px-6 sm:gap-6">
      <GoogleReviewBadge locale={locale} variant="inline" asLink={false} />
      <Badge label={t.trust.insured} tone="brand" caps={false} class="!text-navy">
        <svg slot="icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-midnight-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
      </Badge>
      <Badge label={t.servicesPage.trustGuarantee} tone="brand" caps={false} class="!text-navy">
        <svg slot="icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-midnight-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </Badge>
    </div>

    <div class="mx-auto max-w-7xl px-4 md:px-6">
      <h2 class="sr-only">{isFr ? 'Nos Services' : 'Our Services'}</h2>
      <ServiceCardMarquee services={services} locale={locale} learnMoreText={t.ui.learnMore} />
      <div class="hidden md:grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service, i) => (
          <ServiceCard
            service={service}
            locale={locale}
            featured={i === 0}
            learnMoreText={t.ui.learnMore}
            delayClass={`delay-${Math.min(i + 1, 5)}`}
          />
        ))}
      </div>
    </div>

    <!-- Bottom CTA Section -->
    <div class="mx-auto max-w-7xl px-4 md:px-6">
      <div class="mt-12 rounded-xl bg-midnight-indigo px-6 py-8 text-center text-text-on-dark sm:px-10">
        <h2 class="font-heading heading-card font-extrabold">{t.servicesPage.ctaReady}</h2>
        <p class="mt-2 text-text-on-dark-muted">{t.servicesPage.ctaDescription}</p>
        <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <a href={`/${locale}/contact`} class="touch-target inline-flex items-center rounded-full bg-text-on-dark px-8 py-3 text-lg font-semibold uppercase tracking-wider text-midnight-indigo shadow-lg transition-colors duration-200 hover:bg-text-on-dark/90 hover:shadow-xl focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2">
            {t.cta.freeQuote}
          </a>
          <a href={`tel:${cms.phoneLink}`} class="touch-target inline-flex items-center gap-2 rounded-full border-2 border-text-on-dark/30 px-8 py-3 text-lg font-semibold uppercase tracking-wider text-text-on-dark transition-colors duration-200 hover:border-text-on-dark/60 hover:bg-text-on-dark/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {cms.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
