{
  "name": "all-star-cleaning",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:serve": "serve storybook-static -p 6006",
    "lint": "eslint src --ext .astro,.ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src --ext .astro,.ts,.tsx,.js,.jsx --fix",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:coverage": "playwright test --coverage",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:visual": "playwright test --project=visual-regression",
    "test:a11y": "playwright test --project=accessibility",
    "test:all": "npm run test:unit && npm run test",
    "validate": "npm run lint && npm run typecheck && npm run test:unit",
    "validate:ci": "npm run lint && npm run typecheck && npm run test:unit:coverage && npm run test:coverage",
    "storybook:test": "test-storybook",
    "analyze": "npx @rollup/plugin-visualizer",
    "hooks:install": "husky install",
    "hooks:add": "husky add",
    "clean": "rm -rf dist .astro node_modules/.vite node_modules/.astro coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/markdoc": "^2.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@keystatic/astro": "^5.1.0",
    "@keystatic/core": "^0.5.50",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.0",
    "astro-icon": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "postcss": "^8.5.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-designs": "^11.1.4",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-toolbars": "^9.0.8",
    "@storybook/addon-viewport": "^9.0.8",
    "@storybook/builder-vite": "^10.5.0",
    "@storybook/react": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@storybook/testing-library": "^0.2.1",
    "@storybook/theming": "^8.6.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "terser": "^5.48.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
